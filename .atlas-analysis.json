  "keyFeatures": [
    "Multi-device WhatsApp support with independent device management",
    "Comprehensive REST API with OpenAPI specification",
    "MCP (Model Context Protocol) server for AI agent integration",
    "Webhook system with event filtering and HMAC security",
    "Chatwoot CRM integration for customer support",
    "Media handling (images, audio, video, stickers) with auto-compression",
    "Group management with participant controls",
    "Auto-reply, auto-read, and auto-download capabilities",
    "Docker and binary deployment options",
    "Basic authentication and subpath deployment support"
  ],
  "publicApiSurface": [
    "GET /devices - List all registered devices",
    "POST /devices - Add new device",
    "GET /devices/:device_id/login - Login with QR code",
    "POST /devices/:device_id/login/code - Login with pairing code",
    "POST /send/message - Send text message",
    "POST /send/image - Send image with compression",
    "POST /send/sticker - Send sticker (auto WebP conversion)",
    "POST /send/audio - Send audio message",
    "POST /send/video - Send video with compression",
    "POST /send/file - Send document",
    "POST /send/contact - Send contact card",
    "POST /send/location - Send GPS location",
    "POST /send/poll - Send poll/vote",
    "GET /user/info - Get user profile",
    "GET /user/my/contacts - List contacts",
    "GET /user/my/groups - List groups (max 500)",
    "POST /group/create - Create new group",
    "POST /group/participants - Manage group members",
    "GET /chats - List chat conversations",
    "GET /chat/:chat_jid/messages - Get chat messages",
    "POST /message/:message_id/revoke - Delete message",
    "POST /message/:message_id/reaction - React with emoji",
    "GET /message/:message_id/download - Download media",
    "Webhook events: message, message.ack, group.participants, newsletter.message, call.offer",
    "MCP tools: whatsapp_send_text, whatsapp_login_qr, whatsapp_group_create, whatsapp_list_contacts"
  ]
